{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "afterAgentThought": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "postToolUse": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "sessionStart": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "subagentStart": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/hooks/codex-agents-office.cjs"
      }
    ]
  }
}
